# Foundry Ops — environment variables
# Copy to .env.local for local dev; never commit .env* files.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database (populated in TASK-002)
# DATABASE_URL=postgresql://foundry:foundry@localhost:5432/foundry_ops
# DIRECT_URL=postgresql://foundry:foundry@localhost:5432/foundry_ops

# Auth (populated in TASK-004)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=

# Integrations (populated in their respective tasks)
# ANTHROPIC_API_KEY=
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_WEBHOOK_KEY=
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_SECRET=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# PAYDOTCOMAU_API_KEY=

# Feature flags (populated per integration task)
# ENABLE_PROVISIONING=0
# ENABLE_XERO_PUSH=0
# ENABLE_PAYDOTCOMAU=0
# ENABLE_WHATSAPP_OUTBOUND=0
# ENABLE_WHATSAPP_INBOUND=0
# ENABLE_DOCUSIGN_SEND=0
# ENABLE_TEAMS_NOTIFICATIONS=0
# ENABLE_ROLE_SWITCHER=0
