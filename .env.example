# Foundry Ops — environment variables
# Copy to .env.local for local dev; never commit .env* files.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database — Supabase (TASK-002)
# Get these from: Supabase project → Settings → Database → Connection string
# DATABASE_URL = pooled connection (via Supavisor / pgbouncer), used by the app at runtime
# DIRECT_URL   = direct connection (non-pooled), used by prisma migrate
# DATABASE_URL=postgresql://postgres.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# Supabase also exposes service role + anon keys for client SDK use (not needed yet):
# SUPABASE_URL=https://<project_ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=

# Auth — Entra ID SSO (TASK-004)
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# Magic-link email for contractors (TASK-004b — Resend)
RESEND_API_KEY=
EMAIL_FROM=auth@foundry.health

# SharePoint — provisioning project folders via Graph (TASK-031)
# Leave blank to disable; provisioning skips silently when unset.
# Team-side has two modes:
#   (a) Set SHAREPOINT_TEAM_TEMPLATE_PATH — deep-copies that template folder into
#       every new project; any folder containing [PROJECT CODE] (case-insensitive)
#       gets renamed with the real project code substituted.
#   (b) Leave TEAM_TEMPLATE_PATH unset — SHAREPOINT_TEAM_SUBFOLDERS creates flat
#       subfolders at the project level.
# Values containing spaces MUST be quoted. Paths match case-insensitively in Graph
# but use exact casing to avoid ambiguity. Foundry's verified values below.
# SHAREPOINT_SITE_URL=https://<tenant>.sharepoint.com/sites/<SiteName>
# SHAREPOINT_CLIENTS_ROOT="CORPORATE/TEAM ACCESS/01 Client Projects/01 Active Clients"
# SHAREPOINT_ADMIN_ROOT="CORPORATE/ADMIN ACCESS/00 Administration/03 Financial/02 Project Administration"
# SHAREPOINT_TEAM_TEMPLATE_PATH="CORPORATE/TEAM ACCESS/01 Client Projects/00 New Client Folder System/01 [CLIENT CODE] Projects/[COPY THIS TO EVERY NEW PROJECT CODE]"
# SHAREPOINT_TEAM_SUBFOLDERS="01 Brief,02 Working,03 Delivery,04 Admin"  # fallback only — ignored when TEMPLATE_PATH set
# SHAREPOINT_ADMIN_SUBFOLDERS=""  # flat admin folder (Foundry's convention)
#
# SHAREPOINT_CLIENTS_ROOT = folder under the default drive where
# /Clients/<ClientCode>/<ProjectCode> lives (default: "Clients").
# SHAREPOINT_SITE_URL=
# SHAREPOINT_CLIENTS_ROOT=Clients

# Feature flags (populated per integration task)
# ENABLE_PROVISIONING=0  # M365 user create via Graph on New Person wizard (TASK-023)
# ENABLE_SHAREPOINT=0    # SharePoint folder auto-provision on Project create (TASK-031)

# Integrations (populated in their respective tasks)
# ANTHROPIC_API_KEY=
# Xero developer app creds (developer.xero.com → My Apps → New app). TASK-050.
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_WEBHOOK_KEY=
# Optional: Xero Chart-of-Accounts codes Foundry writes invoices/bills against.
# When unset Xero uses the org default (usually fine; set explicitly if you
# want AR/AP landing in specific GL accounts).
# XERO_SALES_ACCOUNT_CODE=200
# XERO_EXPENSE_ACCOUNT_CODE=453

# Cron — shared secret Vercel Cron sends as Authorization: Bearer <CRON_SECRET>.
# Generate with: openssl rand -base64 32
# CRON_SECRET=

# ABA (Cemtext) file generator — Foundry's CBA account that pay-runs debit.
# APCA user ID is 6 digits, issued by CBA when direct-entry is enabled on
# the account. Verify with your relationship manager before live pay runs.
# ABA_USER_BSB=062-001
# ABA_USER_ACCOUNT=12345678
# ABA_USER_ID=301500
# ABA_USER_NAME=FOUNDRY HEALTH PTY LTD
# ABA_BANK_ABBREV=CBA
# ABA_REMITTER_NAME=FOUNDRY HEALTH
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_SECRET=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# PAYDOTCOMAU_API_KEY=

# Feature flags (populated per integration task)
# ENABLE_PROVISIONING=0
# ENABLE_XERO_PUSH=0
# ENABLE_PAYDOTCOMAU=0
# ENABLE_WHATSAPP_OUTBOUND=0
# ENABLE_WHATSAPP_INBOUND=0
# ENABLE_DOCUSIGN_SEND=0
# ENABLE_TEAMS_NOTIFICATIONS=0
# ENABLE_ROLE_SWITCHER=0
